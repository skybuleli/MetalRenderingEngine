<Project>

  <!--
    MetalShaders.targets
    自动编译源生成器输出的 Slang 着色器为 .metallib。
    在 CoreCompile 后运行，将生成的 .metallib 复制到输出目录。
  -->

  <PropertyGroup>
    <GeneratedShaderDir>$(IntermediateOutputPath)Generated/MetalRenderingEngine.ShaderGen/MetalRenderingEngine.ShaderGen.ShaderGenerator</GeneratedShaderDir>
    <ShaderOutputDir>$(IntermediateOutputPath)shaders</ShaderOutputDir>
    <CompileGeneratedShadersScript>$(MSBuildThisFileDirectory)../compile_generated_shaders.sh</CompileGeneratedShadersScript>
  </PropertyGroup>

  <!-- 编译生成着色器，在 CoreCompile 之后运行（源生成器此时已输出 .Slang.g.cs） -->
  <Target Name="CompileGeneratedShaders"
          AfterTargets="CoreCompile"
          Condition="Exists('$(GeneratedShaderDir)')">

    <Exec Command="chmod +x '$(CompileGeneratedShadersScript)'" StandardOutputImportance="low" />
    <Exec Command="bash '$(CompileGeneratedShadersScript)' '$(GeneratedShaderDir)' '$(ShaderOutputDir)'"
          StandardOutputImportance="high" />
  </Target>

  <!-- 将 metallib 复制到输出目录 -->
  <Target Name="CopyGeneratedMetallibs"
          AfterTargets="CompileGeneratedShaders"
          Condition="Exists('$(ShaderOutputDir)')">

    <ItemGroup>
      <_GenMetallib Include="$(ShaderOutputDir)/*.generated.metallib" />
    </ItemGroup>

    <Copy SourceFiles="@(_GenMetallib)"
          DestinationFolder="$(OutDir)shaders"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- 清理 -->
  <Target Name="CleanGeneratedShaders" AfterTargets="Clean">
    <RemoveDir Directories="$(ShaderOutputDir)" Condition="Exists('$(ShaderOutputDir)')" />
  </Target>

</Project>
