<Project>

  <!--
    MetalShaders.targets
    自动编译源生成器输出的 Slang 着色器为 .metallib。
    在 CoreCompile 后运行，将生成的 .metallib 复制到输出目录。
  -->

  <PropertyGroup>
    <!-- CompilerGeneratedFilesOutputPath 在各项目 csproj 中设为 obj/Generated（非 IntermediateOutputPath），
         故生成文件落在 obj/Generated/<GeneratorName>/，而非 obj/<Config>/<TFM>/Generated/...。
         此处必须与 csproj 的设置保持一致，否则 Exists() 为 false、target 永不执行。 -->
    <GeneratedShaderDir>$(CompilerGeneratedFilesOutputPath)/MetalRenderingEngine.ShaderGen/MetalRenderingEngine.ShaderGen.ShaderGenerator</GeneratedShaderDir>
    <ShaderOutputDir>$(IntermediateOutputPath)shaders</ShaderOutputDir>
    <CompileGeneratedShadersScript>$(MSBuildThisFileDirectory)../compile_generated_shaders.sh</CompileGeneratedShadersScript>
    <GenerateBindingsScript>$(MSBuildThisFileDirectory)../generate_bindings.py</GenerateBindingsScript>
  </PropertyGroup>

  <!-- 编译生成着色器，在 CoreCompile 之后运行（源生成器此时已输出 .Slang.g.cs） -->
  <Target Name="CompileGeneratedShaders"
          AfterTargets="CoreCompile"
          Condition="Exists('$(GeneratedShaderDir)')">

    <Exec Command="chmod +x '$(CompileGeneratedShadersScript)'" StandardOutputImportance="low" />
    <Exec Command="bash '$(CompileGeneratedShadersScript)' '$(GeneratedShaderDir)' '$(ShaderOutputDir)'"
          StandardOutputImportance="high" />
  </Target>

  <!-- 从 reflect.json 提炼运行时 bindings.json -->
  <Target Name="GenerateBindingMetadata"
          AfterTargets="CompileGeneratedShaders"
          Condition="Exists('$(ShaderOutputDir)')">

    <Exec Command="python3 '$(GenerateBindingsScript)' --emit-cs '$(ShaderOutputDir)'"
          StandardOutputImportance="high" />
  </Target>

  <!-- 将 metallib 与 reflect.json 复制到输出目录（Phase 10D: 反射供 ReflectionLoader 运行时加载） -->
  <Target Name="CopyGeneratedMetallibs"
          AfterTargets="GenerateBindingMetadata"
          Condition="Exists('$(ShaderOutputDir)')">

    <ItemGroup>
      <_GenMetallib Include="$(ShaderOutputDir)/*.generated.metallib" />
      <_GenReflection Include="$(ShaderOutputDir)/*.generated.reflect.json" />
      <_GenBindings Include="$(ShaderOutputDir)/*.generated.bindings.json" />
      <_GenBindingLayouts Include="$(ShaderOutputDir)/*.BindingLayout.g.cs" />
    </ItemGroup>

    <Copy SourceFiles="@(_GenMetallib)"
          DestinationFolder="$(OutDir)shaders"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_GenReflection)"
          DestinationFolder="$(OutDir)shaders"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_GenBindings)"
          DestinationFolder="$(OutDir)shaders"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_GenBindingLayouts)"
          DestinationFolder="$(OutDir)shaders"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- 清理 -->
  <Target Name="CleanGeneratedShaders" AfterTargets="Clean">
    <RemoveDir Directories="$(ShaderOutputDir)" Condition="Exists('$(ShaderOutputDir)')" />
  </Target>

</Project>
